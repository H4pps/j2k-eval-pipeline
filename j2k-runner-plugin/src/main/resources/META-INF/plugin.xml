<idea-plugin>
  <id>iurii.bulanov.j2k-runner</id>
  <name>J2K Runner Plugin</name>
  <vendor email="iurii.bulanov@example.com">Iurii Bulanov</vendor>
  <description><![CDATA[
    Headless static J2K runner used by the benchmark evaluation pipeline.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.java</depends>
  <depends>org.jetbrains.kotlin</depends>

  <extensions defaultExtensionNs="com.intellij">
    <appStarter id="j2k-convert" implementation="iurii.bulanov.j2k.runner.J2kConvertStarter"/>
    <lang.jvm.bytecodeAnalysisSuppressor implementation="iurii.bulanov.j2k.runner.J2kBytecodeAnalysisSuppressor"/>
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
  </extensions>
</idea-plugin>
