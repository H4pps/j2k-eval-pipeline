#!/usr/bin/env bash
set -euo pipefail

readonly IMAGE="${J2K_LOCAL_RUNNER_IMAGE:-j2k-eval-local-runner:latest}"
readonly REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly CACHE_ROOT="${J2K_LOCAL_CACHE_ROOT:-.local-run}"
readonly IMAGE_CONTEXT="${REPO_ROOT}/docker/local-runner"

usage() {
  printf '%s\n' \
    "Usage:" \
    "  ./scripts/docker-run-local hikaricp [--checkout-only]" \
    "  ./scripts/docker-run-local spring-petclinic [--checkout-only]" \
    "  ./scripts/docker-run-local j2k-edge-cases [--checkout-only]" \
    "  ./scripts/docker-run-local all [--checkout-only]" \
    "  ./scripts/docker-run-local benchmarks/<name>.yml [--checkout-only]" \
    "" \
    "Environment overrides:" \
    "  J2K_LOCAL_RUNNER_IMAGE=${IMAGE}" \
    "  J2K_LOCAL_CACHE_ROOT=${CACHE_ROOT}" \
    "  J2K_LOCAL_PLATFORM=<optional docker platform, for example linux/amd64>" \
    "  J2K_LOCAL_REBUILD=1"
}

# Builds the local runner image when it is missing or explicitly requested.
ensure_image() {
  if [[ "${J2K_LOCAL_REBUILD:-0}" == "1" ]] || ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
    docker build -t "${IMAGE}" "${IMAGE_CONTEXT}"
  fi
}

# Starts the runner with host-user ownership so build outputs remain editable.
run_in_container() {
  local docker_args=(
    run
    --rm
    -e "CI=true"
    -e "HOME=/workspace/${CACHE_ROOT}/home"
    -e "GRADLE_USER_HOME=/workspace/${CACHE_ROOT}/gradle"
    -u "$(id -u):$(id -g)"
    -v "${REPO_ROOT}:/workspace"
    -w /workspace
  )

  if [[ -t 0 && -t 1 ]]; then
    docker_args+=(-it)
  fi

  if [[ -n "${J2K_LOCAL_PLATFORM:-}" ]]; then
    docker_args+=(--platform "${J2K_LOCAL_PLATFORM}")
  fi

  exec docker "${docker_args[@]}" "${IMAGE}" ./scripts/run-j2k-eval "$@"
}

main() {
  if [[ "${1:-}" == "" || "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
    usage
    exit 0
  fi

  mkdir -p \
    "${REPO_ROOT}/${CACHE_ROOT}/gradle" \
    "${REPO_ROOT}/${CACHE_ROOT}/home" \
    "${REPO_ROOT}/${CACHE_ROOT}/m2"

  ensure_image
  run_in_container "$@"
}

main "$@"
