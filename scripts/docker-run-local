#!/usr/bin/env bash
set -euo pipefail

readonly IMAGE="${J2K_LOCAL_RUNNER_IMAGE:-j2k-eval-local-runner:latest}"
readonly REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly CACHE_ROOT="${J2K_LOCAL_CACHE_ROOT:-.local-run}"
readonly ARTIFACT_DIR="${J2K_LOCAL_ARTIFACT_DIR:-${CACHE_ROOT}/artifacts}"
readonly DOCKERFILE="${REPO_ROOT}/docker/local-runner/Dockerfile"

usage() {
  printf '%s\n' \
    "Usage:" \
    "  ./scripts/docker-run-local hikaricp [--checkout-only]" \
    "  ./scripts/docker-run-local spring-petclinic [--checkout-only]" \
    "  ./scripts/docker-run-local j2k-edge-cases [--checkout-only]" \
    "  ./scripts/docker-run-local all [--checkout-only]" \
    "  ./scripts/docker-run-local benchmarks/<name>.yml [--checkout-only]" \
    "  ./scripts/docker-run-local hikaricp --kind k2" \
    "  ./scripts/docker-run-local hikaricp --parallel" \
    "" \
    "Environment overrides:" \
    "  J2K_LOCAL_RUNNER_IMAGE=${IMAGE}" \
    "  J2K_LOCAL_CACHE_ROOT=${CACHE_ROOT}" \
    "  J2K_LOCAL_ARTIFACT_DIR=${ARTIFACT_DIR}" \
    "  J2K_LOCAL_PLATFORM=<optional docker platform, for example linux/amd64>" \
    "" \
    "Runs the full local converter-kind matrix. Local output is a single zip under ${ARTIFACT_DIR}/."
}

# Builds a local runner image from the current repository snapshot.
build_image() {
  local build_args=(build -t "${IMAGE}" -f "${DOCKERFILE}")

  if [[ -n "${J2K_LOCAL_PLATFORM:-}" ]]; then
    build_args+=(--platform "${J2K_LOCAL_PLATFORM}")
  fi

  build_args+=("${REPO_ROOT}")

  docker "${build_args[@]}"
}

# Converts the user target into a stable artifact file name.
artifact_name() {
  local target="$1"
  local name

  if [[ "${target}" == *.yml ]]; then
    name="$(basename "${target}" .yml)"
  else
    name="${target}"
  fi

  name="${name//[^A-Za-z0-9._-]/-}"
  printf 'j2k-eval-%s.zip\n' "${name}"
}

# Starts the image-local pipeline and exports only the final zip artifact.
run_in_container() {
  local artifact="$1"
  shift

  local docker_args=(
    run
    --rm
    -e "CI=true"
    -e "HOME=/cache/home"
    -e "GRADLE_USER_HOME=/cache/gradle"
    -u "$(id -u):$(id -g)"
    -v "${REPO_ROOT}/${CACHE_ROOT}/home:/cache/home"
    -v "${REPO_ROOT}/${CACHE_ROOT}/gradle:/cache/gradle"
    -v "${REPO_ROOT}/${ARTIFACT_DIR}:/out"
    -w /workspace
  )

  if [[ -t 0 && -t 1 ]]; then
    docker_args+=(-it)
  fi

  if [[ -n "${J2K_LOCAL_PLATFORM:-}" ]]; then
    docker_args+=(--platform "${J2K_LOCAL_PLATFORM}")
  fi

  docker "${docker_args[@]}" "${IMAGE}" ./scripts/run-j2k-eval "$@" --zip-output "/out/${artifact}"
}

main() {
  if [[ "${1:-}" == "" || "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
    usage
    exit 0
  fi

  mkdir -p \
    "${REPO_ROOT}/${CACHE_ROOT}/gradle" \
    "${REPO_ROOT}/${CACHE_ROOT}/home" \
    "${REPO_ROOT}/${ARTIFACT_DIR}"

  local artifact
  artifact="$(artifact_name "$1")"

  build_image
  run_in_container "${artifact}" "$@"

  printf 'Local artifact: %s\n' "${REPO_ROOT}/${ARTIFACT_DIR}/${artifact}"
}

main "$@"
