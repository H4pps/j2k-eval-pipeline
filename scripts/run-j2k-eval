#!/usr/bin/env bash
set -euo pipefail

readonly REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly DEFAULT_BENCHMARKS=("hikaricp" "spring-petclinic" "j2k-edge-cases")

usage() {
  printf '%s\n' \
    "Usage:" \
    "  ./scripts/run-j2k-eval hikaricp [--checkout-only]" \
    "  ./scripts/run-j2k-eval spring-petclinic [--checkout-only]" \
    "  ./scripts/run-j2k-eval j2k-edge-cases [--checkout-only]" \
    "  ./scripts/run-j2k-eval all [--checkout-only]" \
    "  ./scripts/run-j2k-eval benchmarks/<name>.yml [--checkout-only]" \
    "" \
    "This runs the same local pipeline steps as GitHub Actions:" \
    "  checkout-benchmark -> convertBenchmark -> evaluate"
}

# Resolves a short benchmark alias to the matching checked-in YAML config.
benchmark_config() {
  case "$1" in
    hikaricp) printf '%s\n' "benchmarks/hikaricp.yml" ;;
    spring-petclinic) printf '%s\n' "benchmarks/spring-petclinic.yml" ;;
    j2k-edge-cases) printf '%s\n' "benchmarks/j2k-edge-cases.yml" ;;
    *)
      if [[ -f "$1" ]]; then
        printf '%s\n' "$1"
      else
        echo "Unknown benchmark alias or config path: $1" >&2
        exit 1
      fi
      ;;
  esac
}

# Computes the report/log directory name from the benchmark config file name.
benchmark_id_from_config() {
  basename "$1" .yml
}

# Runs Gradle with common local settings. The cache redirector is disabled here
# because local Docker DNS is less reliable than direct JetBrains repository URLs.
run_gradle() {
  ./gradlew --no-daemon --console=plain -Porg.jetbrains.intellij.platform.useCacheRedirector=false "$@"
}

# Executes the checkout, conversion, and evaluation steps for one benchmark.
run_benchmark() {
  local config="$1"
  local checkout_only="$2"
  local benchmark_id

  benchmark_id="$(benchmark_id_from_config "${config}")"

  echo "==> Checking out ${config}"
  run_gradle run --args="checkout-benchmark --config ${config}"

  if [[ "${checkout_only}" == "1" ]]; then
    echo "==> Checkout-only mode enabled; skipping conversion and evaluation"
    return
  fi

  echo "==> Running static J2K for ${config}"
  mkdir -p "build/j2k/${benchmark_id}/logs"
  run_gradle --stacktrace convertBenchmark -PbenchmarkConfig="${config}" 2>&1 \
    | tee "build/j2k/${benchmark_id}/logs/gradle-convert.log"

  echo "==> Evaluating generated Kotlin for ${config}"
  run_gradle run --args="evaluate --config ${config}"
}

main() {
  if [[ "${1:-}" == "" || "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
    usage
    exit 0
  fi

  local target="$1"
  shift

  local checkout_only=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --checkout-only) checkout_only=1 ;;
      *)
        echo "Unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
    esac
    shift
  done

  cd "${REPO_ROOT}"

  if [[ "${target}" == "all" ]]; then
    local benchmark
    for benchmark in "${DEFAULT_BENCHMARKS[@]}"; do
      run_benchmark "$(benchmark_config "${benchmark}")" "${checkout_only}"
    done
  else
    run_benchmark "$(benchmark_config "${target}")" "${checkout_only}"
  fi
}

main "$@"
